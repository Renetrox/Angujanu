	#InsetX, Y = topleft location to start displaying text
	#Widgetname = the file name of the python searchbar module without '.py' on the end.
	<SearchBarSettings  X="22" Y="47" Width="223" Height="22" Widget="Custom" WidgetName="SearchBar" InitialText="Search programs and files" InsetX="6" InsetY="16" style = "italic" Background="m_searchbar_light.png"/>
